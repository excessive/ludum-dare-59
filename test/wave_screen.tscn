[sub_resource type="GDScript" id="GDScript_57kv7"]
script/source = "extends Node3D

@export var editable := false
@export var wave: WaveParams
@export var target_wave: WaveParams
@export var tool_state: ToolState
var last_pos := Vector2.ZERO

@export_color_no_alpha var wave_unaligned_color := Color.ORANGE_RED
@export_color_no_alpha var wave_aligned_color := Color.GREEN_YELLOW

signal alignment_changed(aligned: bool)
var was_aligned := false

func _check_align():
	var alignment := absf(wave.wave_alignment(target_wave))
	var aligned := alignment > 0.998
	%smash.disabled = not aligned
	%sync.self_modulate = wave_unaligned_color.blend(Color(wave_aligned_color, smoothstep(0.999, 1.0, alignment)))
	%wave.default_color = %sync.self_modulate
	if aligned != was_aligned:
		alignment_changed.emit(aligned)
	was_aligned = aligned

func _ready() -> void:
	%wave.wave = wave
	%target.wave = target_wave
	%phase.editable = editable
	%offset.editable = editable
	%gain.editable = editable
	%frequency.editable = editable
	%phase.set_value_no_signal(wave.phase)
	%offset.set_value_no_signal(wave.offset)
	%gain.set_value_no_signal(wave.gain)
	%frequency.set_value_no_signal(wave.frequency)
	_check_align()
	%phase.value_changed.connect(func(new_value: float):
		wave.phase = new_value
		_check_align()
	)
	%offset.value_changed.connect(func(new_value: float):
		wave.offset = new_value
		_check_align()
	)
	%gain.value_changed.connect(func(new_value: float):
		wave.gain = new_value
		_check_align()
	)
	%frequency.value_changed.connect(func(new_value: float):
		wave.frequency = new_value
		_check_align()
	)

func _process(_delta: float) -> void:
	if not editable:
		%phase.set_value_no_signal(wave.phase)
		%offset.set_value_no_signal(wave.offset)
		%gain.set_value_no_signal(wave.gain)
		%frequency.set_value_no_signal(wave.frequency)

	var cam := get_viewport().get_camera_3d()
	if not cam:
		return

	var center := get_viewport().get_visible_rect().get_center()
	var rp := cam.project_ray_origin(center)

	var screen := $MeshInstance3D
	var dist := rp.distance_to(global_position)
	var sv := ($SubViewport as SubViewport)
	if dist > 15:
		sv.render_target_update_mode = SubViewport.UPDATE_DISABLED
		return
	sv.render_target_update_mode = SubViewport.UPDATE_WHEN_VISIBLE
	if dist > 2.0:
		return
	var rd := cam.project_ray_normal(center)
	var sp := Plane(screen.global_basis.z, screen.global_position)
	var hit = sp.intersects_ray(rp, rd)
	if hit is Vector3:
		var mesh := screen.mesh as PlaneMesh
		var local_hit: Vector3 = screen.to_local(hit)
		var uv := Vector2(local_hit.x, -local_hit.y) / mesh.size + Vector2(0.5, 0.5) # why
		var svp: Vector2 = $SubViewport.size
		var margin := 0.1
		var active_range := Rect2(Vector2.ONE * -margin, Vector2.ONE * (1.0 + margin))
		if active_range.has_point(uv):
			uv = uv.clamp(Vector2.ZERO, Vector2.ONE)
			_screen_input(uv * svp, uv)

func _screen_input(pos: Vector2, _uv: Vector2):
	var pressed := Input.is_action_just_pressed(\"interact\")
	var released := Input.is_action_just_released(\"interact\")
	var held := Input.is_action_pressed(\"interact\")
	%cursor.global_position = pos.round()
	tool_state.block()
	if held:
		%cursor.hold()
	if pressed:
		%cursor.click()

	if pressed or released:
		var event := InputEventMouseButton.new()
		event.button_index = MOUSE_BUTTON_LEFT
		event.position = pos
		event.pressed = pressed
		$SubViewport.push_input(event, true)

	var move_event := InputEventMouseMotion.new()
	move_event.position = pos
	move_event.relative = pos - last_pos
	move_event.relative = move_event.relative.limit_length(100)
	move_event.button_mask = MOUSE_BUTTON_MASK_LEFT
	$SubViewport.push_input(move_event, true)
	last_pos = pos


func _on_button_pressed() -> void:
	print(\"waoooooo\")
"

