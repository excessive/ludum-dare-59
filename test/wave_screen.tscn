[sub_resource type="GDScript" id="GDScript_475l4"]
script/source = "extends Sprite2D

@onready var bubble = $Sprite2D
var holding := 0.0

var anim: Tween

func _ready() -> void:
	bubble.hide()
	bubble.modulate.a = 0

func click():
	if anim and anim.is_valid():
		anim.kill()
	anim = create_tween()
	bubble.show()
	bubble.scale = Vector2.ONE * 0.25
	bubble.modulate.a = 0.75
	anim.set_ease(Tween.EASE_OUT)
	anim.set_trans(Tween.TRANS_CUBIC)
	anim.tween_property(bubble, \"modulate:a\", 0, 0.5)
	anim.parallel().tween_property(bubble, \"scale\", Vector2.ONE, 0.5)

func hold():
	holding = 2.0/Engine.physics_ticks_per_second

func _physics_process(delta: float) -> void:
	if anim and not anim.is_valid():
		anim = null
	if holding > 0:
		var weight := 1.0 - exp(-10 * delta)
		self_modulate = self_modulate.blend(Color(Color.DARK_ORANGE, weight))
	else:
		var weight := 1.0 - exp(-2.5 * delta)
		self_modulate = self_modulate.blend(Color(Color.WHITE, weight))
	holding = maxf(0.0, holding - delta)
"

