[sub_resource type="GDScript" id="GDScript_jb02g"]
script/source = "@tool
extends Line2D

var time := 0.0

@export var wave: WaveParams
@export_range(1, 10, 1, \"prefer_slider\") var wave_sample_scale := 4
@export var wave_size: Vector2 = Vector2(64, 64)

func wave_sample(i: int, wave_scale: Vector2) -> Vector2:
	const sample_range := 1.0
	var sample_count := wave.frequency * wave_sample_scale
	var sample_step := sample_range / sample_count
	var t := time + i * sample_step
	return Vector2(i, wave.evaluate(t)) * wave_scale + Vector2(0, wave_size.y/2)

func _reset():
	clear_points()
	var sample_count := roundi(wave.frequency * wave_sample_scale)
	var wave_scale := wave.domain_scale(wave_size, sample_count)
	for i in sample_count:
		add_point(wave_sample(i, wave_scale))

func _ready() -> void:
	if not wave:
		return
	_reset()

func _process(delta: float) -> void:
	if not wave:
		return
	time = wrapf(time + delta * (1.0 + wave.drift), 0, TAU)
	var sample_count := roundi(wave.frequency * wave_sample_scale)
	if sample_count != get_point_count():
		_reset()
		return
	var wave_scale := wave.domain_scale(wave_size, sample_count)
	for i in sample_count:
		set_point_position(i, wave_sample(i, wave_scale))
"

