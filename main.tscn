[sub_resource type="GDScript" id="GDScript_5vw27"]
script/source = "extends ProgressBar

func _on_lidar_charge_updated(level: float) -> void:
	set_value_no_signal(clampf((1 - level) * 100, 0, 100))
	self_modulate = Color.WHITE.blend(Color(Color.RED, clampf(inverse_lerp(75, 95, value), 0, 1)))

func _on_lidar_channel_updated(channel: LidarChannel) -> void:
	var box := StyleBoxFlat.new()
	box.bg_color = channel.color
	box.set_corner_radius_all(16)
	add_theme_stylebox_override(\"fill\", box)
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_4c57u"]
shader = ExtResource("9_kek77")
shader_parameter/glitch = 0.0
shader_parameter/glitch_color = Color(0, 0, 0, 1)

[sub_resource type="GDScript" id="GDScript_kek77"]
script/source = "extends ColorRect

@export var glitch_speed := 5.0

var glitch := 0.0
var target_color := Color.WHITE

func _on_lidar_channel_updated(channel: LidarChannel) -> void:
	glitch = 1
	target_color = channel.color

func _process(delta: float) -> void:
	glitch = maxf(0, glitch - delta * glitch_speed)
	var mat := material as ShaderMaterial
	mat.set_shader_parameter(&\"glitch\", glitch)
	mat.set_shader_parameter(&\"glitch_color\", target_color * 0.25)
"

