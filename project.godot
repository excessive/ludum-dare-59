config_version=5

[application]

config/name="ludum dare 59"
config/description="maybe we'll get a nice theme for ld69"
run/main_scene="uid://dhg15l3i4jque"
config/features=PackedStringArray("4.7")
boot_splash/bg_color=Color(0.0627451, 0.0627451, 0.0627451, 1)
boot_splash/show_image=false

[autoload]

ControllerIcons="*uid://ba3e8paqa24yb"
Hoarder="*uid://bgmolqwd0hpo"

[display]

window/size/viewport_width=1440
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/controller_icons/plugin.cfg", "res://addons/flickering_light/plugin.cfg", "res://addons/laser_3d/plugin.cfg")

[global_group]

lose_trigger=""
win_trigger=""
player=""
checkpoint=""

