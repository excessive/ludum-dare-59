[sub_resource type="GDScript" id="GDScript_57kv7"]
script/source = "extends Node3D

@export var editable := false
@export var wave: WaveSet
@export var tool_state: ToolState
var last_pos := Vector2.ZERO

@export_color_no_alpha var wave_unaligned_color := Color.ORANGE_RED
@export_color_no_alpha var wave_ready_color := Color.YELLOW
@export_color_no_alpha var wave_aligned_color := Color.GREEN

signal alignment_changed(aligned: bool)
signal alignment_locked()

var was_aligned := false
var was_pressed := false
var blinky := 0.0

@export var player_state: PlayerState

func _update_sync_status(aligned: bool):
	var target_color := wave_unaligned_color
	if aligned:
		if editable:
			target_color = wave_ready_color
			%status.text = \"subsystem status: ready\"
		else:
			target_color = wave_aligned_color
			%status.text = \"subsystem status: synchronized\"
	else:
		%status.text = \"subsystem status: desynchronized\"
	%status.self_modulate = target_color
	%sync.self_modulate = target_color * smoothstep(0.21, 0.3, blinky * float(was_aligned) + float(not editable))
	%smash.self_modulate = Color.WHITE #* smoothstep(0.21, 0.3, blinky * float(was_aligned) + float(not editable))
	%wave.default_color = target_color

func _check_align():
	if not editable:
		return
	var aligned := wave.is_aligned()
	%smash.disabled = not aligned	
	_update_sync_status(aligned)
	if aligned != was_aligned:
		alignment_changed.emit(aligned)
	was_aligned = aligned

func _on_button_pressed() -> void:
	alignment_locked.emit()
	wave.locked = true
	player_state.wavesync(wave)
	%lockout.show()
	%smash.disabled = true
	_update_sync_status(true)
	_set_editable(false)

func _set_editable(_editable):
	editable = _editable
	%phase.editable = _editable
	%offset.editable = _editable
	%gain.editable = _editable
	%frequency.editable = _editable
	%phase.self_modulate.a = 1 # = 0.5 + float(_editable) * 0.5
	%offset.self_modulate.a = 1 # = 0.5 + float(_editable) * 0.5
	%gain.self_modulate.a = 1 # = 0.5 + float(_editable) * 0.5
	%frequency.self_modulate.a = 1 # = 0.5 + float(_editable) * 0.5

func _ready() -> void:
	var timer := Timer.new()
	timer.autostart = true
	timer.wait_time = 0.5
	timer.timeout.connect(_check_align)
	add_child(timer)

	assert(wave is WaveSet)
	%wave.wave = wave.state
	%target.wave = wave.target
	_set_editable(editable)

	%phase.set_value_no_signal(wave.state.phase)
	%offset.set_value_no_signal(wave.state.offset)
	%gain.set_value_no_signal(wave.state.gain)
	%frequency.set_value_no_signal(wave.state.frequency)
	_check_align()
	%phase.value_changed.connect(func(new_value: float):
		wave.state.phase = new_value
		_check_align()
	)
	%offset.value_changed.connect(func(new_value: float):
		wave.state.offset = new_value
		_check_align()
	)
	%gain.value_changed.connect(func(new_value: float):
		wave.state.gain = new_value
		_check_align()
	)
	%frequency.value_changed.connect(func(new_value: float):
		wave.state.frequency = new_value
		_check_align()
	)
	if wave.locked:
		_on_button_pressed()

func _process(_delta: float) -> void:
	%phase.set_value_no_signal(wave.state.phase)
	%offset.set_value_no_signal(wave.state.offset)
	%gain.set_value_no_signal(wave.state.gain)
	%frequency.set_value_no_signal(wave.state.frequency)

	blinky = maxf(0, blinky - _delta)
	if blinky <= 0:
		blinky = 0.5
	_update_sync_status(was_aligned)

	var cam := get_viewport().get_camera_3d()
	if not cam:
		return

	var center := get_viewport().get_visible_rect().get_center()
	var rp := cam.project_ray_origin(center)

	var screen := $MeshInstance3D
	var dist := rp.distance_to(global_position)
	var sv := ($SubViewport as SubViewport)
	if dist > 15:
		sv.render_target_update_mode = SubViewport.UPDATE_DISABLED
		return
	sv.render_target_update_mode = SubViewport.UPDATE_WHEN_VISIBLE
	if dist > 2.0:
		return
	var rd := cam.project_ray_normal(center)
	var sp := Plane(screen.global_basis.z, screen.global_position)
	var hit = sp.intersects_ray(rp, rd)
	var try_release := false
	if hit is Vector3:
		var mesh := screen.mesh as PlaneMesh
		var local_hit: Vector3 = screen.to_local(hit)
		var uv := Vector2(local_hit.x, -local_hit.y) / mesh.size + Vector2(0.5, 0.5) # why
		var svp: Vector2 = $SubViewport.size
		var margin := 0.25
		var active_range := Rect2(Vector2.ONE * -margin, Vector2.ONE * (1.0 + margin))
		if active_range.has_point(uv):
			uv = uv.clamp(Vector2.ZERO, Vector2.ONE)
			_screen_input(uv * svp, uv)
		else:
			try_release = true

	# avoid sticky sliders
	if try_release:
		var event := InputEventMouseButton.new()
		event.button_index = MOUSE_BUTTON_LEFT
		event.position = Vector2(-1, -1)
		event.canceled = true
		$SubViewport.push_input(event, true)
		was_pressed = false

func _screen_input(pos: Vector2, _uv: Vector2):
	var pressed := Input.is_action_just_pressed(\"interact\")
	var released := Input.is_action_just_released(\"interact\")
	var held := Input.is_action_pressed(\"interact\")
	%cursor.global_position = pos.round()
	tool_state.block()
	if held:
		%cursor.hold()
	if pressed:
		%cursor.click()

	if pressed or released:
		was_pressed = pressed
		var event := InputEventMouseButton.new()
		event.button_index = MOUSE_BUTTON_LEFT
		event.position = pos
		event.pressed = pressed
		$SubViewport.push_input(event, true)

	var move_event := InputEventMouseMotion.new()
	move_event.position = pos
	move_event.relative = pos - last_pos
	move_event.relative = move_event.relative.limit_length(100)
	move_event.button_mask = MOUSE_BUTTON_MASK_LEFT
	$SubViewport.push_input(move_event, true)
	last_pos = pos
"

