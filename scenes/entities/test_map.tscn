[sub_resource type="GDScript" id="GDScript_trceg"]
script/source = "extends Area3D

func _ready() -> void:
	_on_wave_checker_alignment_changed(false)

func _on_wave_checker_alignment_changed(aligned: bool) -> void:
	monitorable = aligned
	visible = aligned
"

