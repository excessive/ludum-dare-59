[gd_scene format=3 uid="uid://da8w81ckch4dr"]

[ext_resource type="Script" uid="uid://b7feuq00dikpo" path="res://addons/laser_3d/laser_3d.gd" id="1_xqeyi"]

[sub_resource type="GDScript" id="GDScript_uwd62"]
script/source = "@tool
extends Node3D

@export var lock_wave: WaveSet
@export var channel: LidarChannel
@export var flip_lock := false
@export_range(1, 10, 0.1, \"or_greater\", \"suffix:m\") var length := 10.0
@onready var laser: Laser3D = %laser

func _update():
	var unlock := lock_wave and lock_wave.locked
	if flip_lock:
		unlock = not unlock
	if unlock:
		laser.laser_active = false
		laser.laser_type_visible = Laser3D.LASER_VISIBLE_OFF
	else:
		laser.laser_active = true
		laser.laser_type_visible = Laser3D.LASER_ALWAYS_VISIBLE
	laser.laser_length = length
	if channel:
		laser.laser_color = channel.color
		laser.laser_layers = channel.visibility_mask
		laser.laser_collision_mask = channel.collision_mask

func _ready() -> void:
	_update()
	if lock_wave:
		var timer := Timer.new()
		timer.wait_time = 0.25
		timer.autostart = true
		timer.timeout.connect(_update, CONNECT_DEFERRED)
		add_child(timer)
"

[node name="Laser" type="Node3D" unique_id=198584673]
script = SubResource("GDScript_uwd62")

[node name="laser" type="Node3D" parent="." unique_id=1767954010 groups=["lose_trigger"]]
